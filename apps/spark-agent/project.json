{
  "name": "spark-agent",
  "sourceRoot": "apps/spark-agent/src",
  "projectType": "application",
  "implicitDependencies": ["unifi-connect", "dynamo-schema", "dynamo-repo"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.json",
        "cwd": "apps/spark-agent"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/index.js",
        "cwd": "apps/spark-agent"
      }
    }
  }
}
