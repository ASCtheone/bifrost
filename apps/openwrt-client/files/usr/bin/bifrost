#!/bin/sh
# bifrost — OpenWrt/GL.iNet client for the Bifrost VPN.
#
# Onboards by device code: on first boot it asks the master for a short code,
# which the account owner claims in the dashboard; the master hands back a
# provision token (via the router's callback, or by the router polling). The
# router then fetches its WireGuard config from the hard-bound master and brings
# up a tunnel to a spark — either a chosen location or, on "auto", the primary
# with failover to the next available node and automatic return to primary.
#
# A kill switch (optional) blocks LAN clients from reaching the internet unless
# their traffic goes through the tunnel — including while connecting/switching.
#
# Usage: bifrost {bootstrap|save-token <t>|poll|up|down|status|json|refresh|run}
set -u

CONFIG=bifrost
STATE_DIR=/tmp/bifrost
RESP="$STATE_DIR/provision.json"
WGTMP="$STATE_DIR/wg.conf"
HASHFILE="$STATE_DIR/applied.hash"
CURNODE="$STATE_DIR/current.node"
# Hard-bound control plane. Override only for self-hosting via
# `uci set bifrost.settings.master_url=...`.
MASTER_DEFAULT="https://dash.asc.ninja/bifrost"
KS_CHAIN=bifrost_ks
BIFROST_VERSION=0.9.22
# Self-update: a persistent backup + pending marker (STATE_DIR=/tmp is volatile).
UPDATE_DIR=/etc/bifrost
BAK="$UPDATE_DIR/bifrost.bak"
PENDING="$UPDATE_DIR/.update-pending"

mkdir -p "$STATE_DIR"

log() { logger -t bifrost "$*"; [ -t 1 ] && echo "bifrost: $*"; }
cfg_get() { uci -q get "${CONFIG}.settings.$1"; }
cfg_set() { uci set "${CONFIG}.settings.$1=$2" && uci commit "$CONFIG"; }

ifname() { local n; n=$(cfg_get ifname); [ -n "$n" ] && echo "$n" || echo bifrost; }
lan_dev() { local d; d=$(uci -q get network.lan.device); [ -n "$d" ] && echo "$d" || echo br-lan; }
lan_ip() { uci -q get network.lan.ipaddr 2>/dev/null || echo 192.168.8.1; }
master() { local m; m=$(cfg_get master_url); [ -n "$m" ] && echo "$m" || echo "$MASTER_DEFAULT"; }
api() { echo "$(master)/api"; }
jget() { jq -r "$2 // empty" 2>/dev/null <<EOF
$1
EOF
}

# ── device-code onboarding ──────────────────────────────────────

callback_url() { echo "http://$(lan_ip):8099/cgi-bin/bifrost"; }

# Ask the master for a pairing code (first boot). Echoes the code.
bootstrap() {
	[ -n "$(cfg_get provision_token)" ] && { log "already registered"; cfg_get device_code; return 0; }
	local code hostname resp
	code=$(cfg_get device_code)
	if [ -z "$code" ]; then
		hostname=$(uci -q get system.@system[0].hostname 2>/dev/null || echo router)
		resp=$(curl -fsS --max-time 15 -X POST "$(api)/device/code" \
			-H 'Content-Type: application/json' \
			-d "{\"name\":\"$hostname\",\"callbackUrl\":\"$(callback_url)\"}" 2>/dev/null)
		code=$(jget "$resp" .deviceCode)
		[ -n "$code" ] || { log "could not obtain a device code from the master"; return 1; }
		cfg_set device_code "$code"
		log "device code issued: $code"
	fi
	echo "$code"
}

# Save the provision token handed back by the dashboard (callback or poll).
# Config-only: the always-running agent picks it up and connects. Never restarts
# procd (that would kill the web UI serving the callback).
save_token() {
	[ -n "${1:-}" ] || { log "save-token: empty token"; return 1; }
	uci set "${CONFIG}.settings.provision_token=$1"
	uci set "${CONFIG}.settings.device_code="
	uci set "${CONFIG}.settings.enabled=1"
	uci commit "$CONFIG"
	log "registered — provision token saved"
}

# Poll the master once for a claimed code; saves the token when registered.
poll_once() {
	local code resp status token
	code=$(cfg_get device_code)
	[ -n "$code" ] || return 1
	resp=$(curl -fsS --max-time 15 "$(api)/device/code/$code" 2>/dev/null) || return 1
	status=$(jget "$resp" .status)
	case "$status" in
		registered)
			token=$(jget "$resp" .provisionToken)
			[ -n "$token" ] && { save_token "$token"; return 0; }
			;;
		expired) log "device code expired"; cfg_set device_code '' ;;
	esac
	return 1
}

# ── config fetch (by provision token, hard-bound master) ────────

fetch_config() {
	local token backup
	token=$(cfg_get provision_token)
	[ -n "$token" ] || { log "not registered yet (no provision token)"; return 1; }
	backup=0; [ -f "$BAK" ] && backup=1
	if ! curl -fsS --max-time 20 \
		-H "X-Bifrost-Version: $BIFROST_VERSION" \
		-H "X-Bifrost-Backup: $backup" \
		"$(api)/provision/$token" -o "$RESP" 2>/dev/null; then
		log "could not reach master at $(api)"
		return 1
	fi
	jq -e '.nodes' "$RESP" >/dev/null 2>&1 || { log "unexpected provision response"; return 1; }
	handle_pending_action
	return 0
}

# ── remote self-update (opkg + health-gated auto-downgrade) ─────

# Act on a one-shot update/revert instruction the master returned in the provision poll.
handle_pending_action() {
	[ -f "$PENDING" ] && return 0   # already applying an update — don't stack another
	local action latest
	action=$(jq -r '.pendingAction // empty' "$RESP" 2>/dev/null)
	latest=$(jq -r '.latestVersion // empty' "$RESP" 2>/dev/null)
	case "$action" in
		update) [ -n "$latest" ] && [ "$latest" != "$BIFROST_VERSION" ] && do_update ;;
		revert) do_revert ;;
	esac
}

# Back up the current script, then upgrade via opkg — detached (setsid) so restarting the
# service mid-upgrade can't kill it. The new version health-gates itself on startup (see
# the `run` loop) and rolls back if it can't reach the master. Single backup slot; kept
# after a healthy update so a manual Revert can restore it.
do_update() {
	mkdir -p "$UPDATE_DIR"
	cp /usr/bin/bifrost "$BAK" 2>/dev/null || { log "self-update: could not back up current version"; return 1; }
	touch "$PENDING"
	log "self-update: upgrading via opkg (detached)"
	setsid sh -c 'sleep 2; opkg update && opkg upgrade bifrost && /etc/init.d/bifrost restart' \
		>/tmp/bifrost-update.log 2>&1 &
}

# Restore the backup script and drop it, then restart into it.
do_revert() {
	[ -f "$BAK" ] || { log "revert: no backup to restore"; return 1; }
	log "revert: restoring the previous version"
	setsid sh -c "sleep 1; cp '$BAK' /usr/bin/bifrost && rm -f '$BAK' '$PENDING' && /etc/init.d/bifrost restart" \
		>/tmp/bifrost-update.log 2>&1 &
}

# ── WireGuard .conf parsing + apply (uci netifd) ────────────────

wg_field() { sed -n "s/^[[:space:]]*$2[[:space:]]*=[[:space:]]*//p" "$1" | head -n1; }
sha() { sha256sum "$1" 2>/dev/null | awk '{print $1}' || md5sum "$1" | awk '{print $1}'; }

apply_wg() {
	local iface priv addr dns pub psk ep ephost epport allowed mtu peer d a
	iface=$(ifname)
	priv=$(wg_field "$1" PrivateKey)
	addr=$(wg_field "$1" Address)
	dns=$(wg_field "$1" DNS | tr ',' ' ')
	pub=$(wg_field "$1" PublicKey)
	psk=$(wg_field "$1" PresharedKey)
	ep=$(wg_field "$1" Endpoint)
	ephost=${ep%:*}
	epport=${ep##*:}
	allowed=$(wg_field "$1" AllowedIPs | tr ',' ' ')
	mtu=$(cfg_get mtu); [ -n "$mtu" ] || mtu=1420
	if [ -z "$priv" ] || [ -z "$pub" ] || [ -z "$ephost" ]; then
		log "config missing required WireGuard fields"
		return 1
	fi

	uci -q delete "network.$iface"
	uci set "network.$iface=interface"
	uci set "network.$iface.proto=wireguard"
	uci set "network.$iface.private_key=$priv"
	uci set "network.$iface.mtu=$mtu"
	[ -n "$addr" ] && uci add_list "network.$iface.addresses=$addr"
	for d in $dns; do uci add_list "network.$iface.dns=$d"; done

	while uci -q delete "network.@wireguard_${iface}[0]"; do :; done
	peer=$(uci add network "wireguard_${iface}")
	uci set "network.$peer.public_key=$pub"
	[ -n "$psk" ] && uci set "network.$peer.preshared_key=$psk"
	uci set "network.$peer.endpoint_host=$ephost"
	uci set "network.$peer.endpoint_port=$epport"
	uci set "network.$peer.persistent_keepalive=25"
	uci set "network.$peer.route_allowed_ips=1"
	for a in $allowed; do uci add_list "network.$peer.allowed_ips=$a"; done

	uci commit network
	[ "$(cfg_get route_lan)" = "1" ] && setup_firewall "$iface"
	return 0
}

# ── firewall: route LAN out via the tunnel ──────────────────────

setup_firewall() {
	local iface="$1" i name dest z f
	i=0
	while name=$(uci -q get "firewall.@zone[$i].name"); do
		[ "$name" = "bifrost" ] && uci -q delete "firewall.@zone[$i]" || i=$((i + 1))
	done
	i=0
	while dest=$(uci -q get "firewall.@forwarding[$i].dest"); do
		[ "$dest" = "bifrost" ] && uci -q delete "firewall.@forwarding[$i]" || i=$((i + 1))
	done
	z=$(uci add firewall zone)
	uci set "firewall.$z.name=bifrost"
	uci set "firewall.$z.network=$iface"
	uci set "firewall.$z.input=REJECT"
	uci set "firewall.$z.output=ACCEPT"
	uci set "firewall.$z.forward=REJECT"
	uci set "firewall.$z.masq=1"
	uci set "firewall.$z.mtu_fix=1"
	f=$(uci add firewall forwarding)
	uci set "firewall.$f.src=lan"
	uci set "firewall.$f.dest=bifrost"
	uci commit firewall
	/etc/init.d/firewall reload >/dev/null 2>&1
}

# ── kill switch ─────────────────────────────────────────────────
# A self-contained iptables chain (doesn't touch the router's own firewall
# config): LAN clients may only egress via the tunnel interface — everything
# else headed off-LAN is dropped. Because it matches by output interface, it
# blocks leaks whenever the tunnel is down or switching, not just when idle.

killswitch_on() {
	local br iface
	br=$(lan_dev); iface=$(ifname)
	command -v iptables >/dev/null 2>&1 || { log "iptables not found; kill switch unavailable"; return 1; }
	iptables -N "$KS_CHAIN" 2>/dev/null
	iptables -F "$KS_CHAIN"
	iptables -A "$KS_CHAIN" -o "$iface" -j RETURN   # allow: out through the tunnel
	iptables -A "$KS_CHAIN" -o "$br" -j RETURN      # allow: back into the LAN
	iptables -A "$KS_CHAIN" -j DROP                 # block: everything else (WAN)
	iptables -C FORWARD -i "$br" -j "$KS_CHAIN" 2>/dev/null \
		|| iptables -I FORWARD -i "$br" -j "$KS_CHAIN"
	log "kill switch engaged"
}

killswitch_off() {
	command -v iptables >/dev/null 2>&1 || return 0
	iptables -D FORWARD -i "$(lan_dev)" -j "$KS_CHAIN" 2>/dev/null
	iptables -F "$KS_CHAIN" 2>/dev/null
	iptables -X "$KS_CHAIN" 2>/dev/null
	log "kill switch released"
}

apply_killswitch() {
	[ "$(cfg_get killswitch)" = "1" ] && killswitch_on || killswitch_off
}

# ── tunnel health ───────────────────────────────────────────────

handshake_age() {
	local hs now
	hs=$(wg show "$(ifname)" latest-handshakes 2>/dev/null | awk 'NR==1{print $2}')
	[ -n "$hs" ] && [ "$hs" != "0" ] || { echo none; return; }
	now=$(date +%s)
	echo $((now - hs))
}
healthy() { local a; a=$(handshake_age); [ "$a" != none ] && [ "$a" -lt 180 ]; }
wait_handshake() {
	local t=0
	while [ "$t" -lt "$1" ]; do
		[ "$(handshake_age)" != none ] && return 0
		sleep 2; t=$((t + 2))
	done
	return 1
}

# ── node ordering (location: auto|<nodeId>) ─────────────────────

node_order() {
	local loc; loc=$(cfg_get location); [ -n "$loc" ] || loc=auto
	if [ "$loc" = "auto" ]; then
		# primary first, then the rest — this is what enables return-to-primary.
		jq -r '.nodes | to_entries | sort_by(.value.role != "primary") | .[].key' "$RESP"
	else
		jq -r --arg id "$loc" '.nodes | to_entries | map(select(.value.nodeId == $id)) | .[].key' "$RESP"
	fi
}

bring_up() {  # bring_up <node index> ; returns 0 if the tunnel handshakes
	local idx="$1" conf hash
	conf=$(jq -r ".nodes[$idx].wgConfig // empty" "$RESP")
	[ -n "$conf" ] || return 1
	printf '%s\n' "$conf" >"$WGTMP"
	hash=$(sha "$WGTMP")
	if [ "$hash" = "$(cat "$HASHFILE" 2>/dev/null)" ] && healthy; then
		return 0   # already on this exact config and healthy
	fi
	apply_wg "$WGTMP" || return 1
	ifup "$(ifname)" >/dev/null 2>&1
	if wait_handshake 15; then
		echo "$hash" >"$HASHFILE"
		jq -r ".nodes[$idx].nodeId // empty" "$RESP" >"$CURNODE"
		log "connected via $(jq -r ".nodes[$idx].name // .nodes[$idx].nodeId" "$RESP")"
		return 0
	fi
	return 1
}

# ── connect (location-aware, primary-first failover) ────────────

connect() {
	apply_killswitch          # engage before touching the tunnel, so no leak while switching
	fetch_config || return 1
	local order idx
	order=$(node_order)
	[ -n "$order" ] || { log "no usable node for the selected location"; return 1; }
	for idx in $order; do
		if bring_up "$idx"; then
			return 0
		fi
		log "node $(jq -r ".nodes[$idx].nodeId" "$RESP") did not come up, trying next"
	done
	log "could not establish a tunnel to any node"
	return 1
}

# On "auto", if we're healthy but not on the primary, try the primary again so we
# return to it once it's back. Only disrupt when the primary actually comes up.
maybe_return_primary() {
	[ "$(cfg_get location)" = "auto" ] || return 0
	local primary_idx cur primary_id
	primary_idx=$(jq -r '.nodes | to_entries | map(select(.value.role == "primary")) | .[0].key // empty' "$RESP")
	[ -n "$primary_idx" ] || return 0
	primary_id=$(jq -r ".nodes[$primary_idx].nodeId // empty" "$RESP")
	cur=$(cat "$CURNODE" 2>/dev/null)
	[ "$cur" = "$primary_id" ] && return 0    # already on primary
	if bring_up "$primary_idx"; then
		log "returned to primary node"
	fi   # if it fails, the current fallback tunnel is left in place
}

teardown() {
	local iface; iface=$(ifname)
	ifdown "$iface" >/dev/null 2>&1
	uci -q delete "network.$iface"
	while uci -q delete "network.@wireguard_${iface}[0]"; do :; done
	uci commit network
	rm -f "$HASHFILE" "$CURNODE"
}

# ── status ──────────────────────────────────────────────────────

cmd_status() {
	local iface age
	iface=$(ifname)
	echo "Bifrost VPN status"
	echo "  interface:   $iface"
	echo "  master:      $(master)"
	echo "  registered:  $([ -n "$(cfg_get provision_token)" ] && echo yes || echo "no (code: $(cfg_get device_code))")"
	echo "  location:    $(cfg_get location)"
	echo "  kill switch: $([ "$(cfg_get killswitch)" = 1 ] && echo on || echo off)"
	echo "  route LAN:   $([ "$(cfg_get route_lan)" = 1 ] && echo yes || echo no)"
	age=$(handshake_age)
	[ "$age" = none ] && echo "  tunnel:      down" || echo "  tunnel:      up (handshake ${age}s ago)"
	echo
	wg show "$iface" 2>/dev/null || echo "  (interface not present)"
}

cmd_json() {
	local age state token nodes
	age=$(handshake_age)
	[ "$age" = none ] && state=down || state=up
	token=$(cfg_get provision_token)
	# Available locations (from the last provision), for the UI picker.
	nodes='[]'
	[ -f "$RESP" ] && nodes=$(jq -c '[.nodes[] | {nodeId, name, location, role}]' "$RESP" 2>/dev/null || echo '[]')
	printf '{"state":"%s","handshakeAge":"%s","version":"%s","uiUrl":"%s","registered":%s,"deviceCode":"%s","master":"%s","location":"%s","killswitch":%s,"routeLan":%s,"enabled":%s,"currentNode":"%s","nodes":%s}\n' \
		"$state" "$age" "$BIFROST_VERSION" "$(ui_url)" \
		"$([ -n "$token" ] && echo true || echo false)" \
		"$(cfg_get device_code)" "$(master)" "$(cfg_get location)" \
		"$([ "$(cfg_get killswitch)" = 1 ] && echo true || echo false)" \
		"$([ "$(cfg_get route_lan)" = 1 ] && echo true || echo false)" \
		"$([ "$(cfg_get enabled)" = 1 ] && echo true || echo false)" \
		"$(cat "$CURNODE" 2>/dev/null)" "$nodes"
}

# up/down just flip the enabled flag — the always-running agent reacts within a
# cycle (connect or tear down). No procd restart, so the web UI stays alive.
cmd_up() { cfg_set enabled 1; }
cmd_down() { cfg_set enabled 0; }

# ── config page on :80 under a LAN name (bifrost.lan) ───────────
#
# Three pieces:
#   1. a second IP on the LAN bridge (the "alias"), so the name has somewhere of
#      its own to point that isn't the router's address;
#   2. a dnsmasq record mapping bifrost.lan → that alias. dnsmasq is already the
#      resolver for every DHCP client, so this needs no new daemon;
#   3. a NAT redirect: alias:80 → alias:8099, where our uhttpd already listens.
#
# (3) is the subtle one. The obvious approach — a second uhttpd bound to
# <alias>:80 — CANNOT work: GL.iNet's uhttpd binds the wildcard 0.0.0.0:80, which
# occupies port 80 on every address the router owns, alias included. Linux refuses
# an overlapping bind while the existing socket is LISTENing (SO_REUSEADDR does not
# lift that), so the second uhttpd dies with EADDRINUSE and GL.iNet's wildcard
# socket serves the alias — you get their dashboard, not this page.
#
# A DNAT rule sidesteps it: NAT runs in PREROUTING, before the kernel picks a local
# socket, so the packet is already headed for :8099 by the time the wildcard socket
# could have claimed it. GL.iNet's uhttpd is never touched — the rule matches only
# the alias address, so the router's own :80 keeps serving their UI as before.
#
# `.lan`, not `.local`: .local is reserved for mDNS (RFC 6762), and macOS/iOS/
# Windows resolve it only over multicast — a dnsmasq record for it would silently
# fail on exactly those clients. Names under the LAN's own domain always resolve.

# Index of the `lan` firewall zone, so the alias can be added to it explicitly.
ui_lan_zone() {
	local i=0
	while uci -q get "firewall.@zone[$i]" >/dev/null 2>&1; do
		[ "$(uci -q get "firewall.@zone[$i].name")" = lan ] && { echo "$i"; return 0; }
		i=$((i + 1))
	done
	return 1
}

# Pick a free host address in the LAN /24 for the alias: skip the router's own
# address and the whole DHCP pool, so it can never collide with a client.
# Only /24 is handled — anything else keeps the page on :8099 rather than guess.
ui_pick_alias() {
	local lan mask net last start limit pool_end i
	lan=$(lan_ip)
	mask=$(uci -q get network.lan.netmask)
	[ "$mask" = 255.255.255.0 ] || return 1
	net=${lan%.*}; last=${lan##*.}
	start=$(uci -q get dhcp.lan.start); [ -n "$start" ] || start=100
	limit=$(uci -q get dhcp.lan.limit); [ -n "$limit" ] || limit=150
	pool_end=$((start + limit - 1))
	i=2
	while [ "$i" -le 254 ]; do
		if [ "$i" -ne "$last" ] && { [ "$i" -lt "$start" ] || [ "$i" -gt "$pool_end" ]; }; then
			echo "$net.$i"
			return 0
		fi
		i=$((i + 1))
	done
	return 1
}

SSL_DIR=/etc/bifrost/ssl
SSL_CRT="$SSL_DIR/cert.pem"
SSL_KEY="$SSL_DIR/key.pem"

# Generate a self-signed cert for the config page, if we can.
#
# Nothing can issue a *trusted* cert for a .lan name — it isn't a public domain,
# so no CA can validate it. Self-signed is the only option, and browsers will show
# an interstitial the first time. HTTP on :8099 keeps working regardless.
#
# The cert needs a subjectAltName: modern browsers ignore CN entirely and reject a
# SAN-less cert outright rather than offering the click-through. openssl can do
# that; px5g (the tiny OpenWrt generator) generally can't, so it's the fallback.
# If neither exists we skip TLS rather than half-enable it.
ui_cert_ensure() {
	local alias="$1" domain="$2"
	[ -s "$SSL_CRT" ] && [ -s "$SSL_KEY" ] && return 0
	mkdir -p "$SSL_DIR"
	if command -v openssl >/dev/null 2>&1; then
		openssl req -x509 -newkey rsa:2048 -nodes -days 3650 \
			-keyout "$SSL_KEY" -out "$SSL_CRT" \
			-subj "/CN=$domain" \
			-addext "subjectAltName=DNS:$domain,IP:$alias" >/dev/null 2>&1 || return 1
	elif command -v px5g >/dev/null 2>&1; then
		# No SAN support — browsers will flag the name as well as the issuer.
		px5g selfsigned -days 3650 -newkey rsa:2048 \
			-keyout "$SSL_KEY" -out "$SSL_CRT" -subj "/CN=$domain" >/dev/null 2>&1 || return 1
	else
		return 1
	fi
	chmod 0600 "$SSL_KEY"
	[ -s "$SSL_CRT" ] && [ -s "$SSL_KEY" ]
}

# Is HTTPS both wanted and possible?
ui_https_on() {
	[ "$(cfg_get ui_https)" = 0 ] && return 1
	[ -s "$SSL_CRT" ] && [ -s "$SSL_KEY" ]
}

# Idempotent: safe to re-run on upgrade (postinst calls it every install).
cmd_ui_setup() {
	local domain alias dev zone
	domain=$(cfg_get ui_domain); [ -n "$domain" ] || domain=bifrost.lan
	alias=$(cfg_get ui_alias_ip)
	if [ -z "$alias" ]; then
		alias=$(ui_pick_alias) || {
			log "LAN is not a /24 — no port-80 alias; config page stays on :8099"
			return 0
		}
	fi
	dev=$(lan_dev)

	uci set network.bifrost_ui=interface
	uci set network.bifrost_ui.proto=static
	uci set network.bifrost_ui.ipaddr="$alias"
	uci set network.bifrost_ui.netmask=255.255.255.0
	# OpenWrt >= 21 names the L3 device `device`; 19.07 (still common on GL.iNet)
	# calls it `ifname`. Write whichever key this build actually reads.
	if uci -q get network.lan.device >/dev/null 2>&1; then
		uci set network.bifrost_ui.device="$dev"
	else
		uci set network.bifrost_ui.ifname="$dev"
	fi
	uci commit network

	# The alias rides the same bridge, so lan-zone rules already cover it — but
	# say so explicitly rather than depend on that.
	zone=$(ui_lan_zone) && {
		uci -q del_list "firewall.@zone[$zone].network=bifrost_ui"
		uci add_list "firewall.@zone[$zone].network=bifrost_ui"
	}

	# alias:80 → alias:8099, so the page answers on port 80 without a second
	# listener fighting GL.iNet's uhttpd for the port (see the note above).
	# src_dip pins this to the alias: traffic to the router's own :80 is not
	# matched, so the GL.iNet UI is unaffected.
	uci set firewall.bifrost_ui80=redirect
	uci set firewall.bifrost_ui80.name='Bifrost-UI-80'
	uci set firewall.bifrost_ui80.target='DNAT'
	uci set firewall.bifrost_ui80.src='lan'
	uci set firewall.bifrost_ui80.proto='tcp'
	uci set firewall.bifrost_ui80.src_dip="$alias"
	uci set firewall.bifrost_ui80.src_dport='80'
	uci set firewall.bifrost_ui80.dest_ip="$alias"
	uci set firewall.bifrost_ui80.dest_port='8099'

	# HTTPS, same shape: alias:443 → alias:8443. GL.iNet's uhttpd wildcard-binds
	# :443 too when its UI serves HTTPS, so a TLS listener on <alias>:443 would hit
	# exactly the EADDRINUSE trap that :80 did. Redirect instead.
	if [ "$(cfg_get ui_https)" != 0 ] && ui_cert_ensure "$alias" "$domain"; then
		uci set firewall.bifrost_ui443=redirect
		uci set firewall.bifrost_ui443.name='Bifrost-UI-443'
		uci set firewall.bifrost_ui443.target='DNAT'
		uci set firewall.bifrost_ui443.src='lan'
		uci set firewall.bifrost_ui443.proto='tcp'
		uci set firewall.bifrost_ui443.src_dip="$alias"
		uci set firewall.bifrost_ui443.src_dport='443'
		uci set firewall.bifrost_ui443.dest_ip="$alias"
		uci set firewall.bifrost_ui443.dest_port='8443'
		# The DNAT lands on :8443, so the input rule must allow that port.
		uci set firewall.bifrost_ui_tls=rule
		uci set firewall.bifrost_ui_tls.name='Bifrost-UI-TLS'
		uci set firewall.bifrost_ui_tls.src='lan'
		uci set firewall.bifrost_ui_tls.proto='tcp'
		uci set firewall.bifrost_ui_tls.dest_port='8443'
		uci set firewall.bifrost_ui_tls.target='ACCEPT'
	else
		# No cert (no openssl/px5g on this firmware, or explicitly disabled) —
		# tear down any HTTPS bits from a previous install and stay on HTTP.
		uci -q delete firewall.bifrost_ui443
		uci -q delete firewall.bifrost_ui_tls
		[ "$(cfg_get ui_https)" != 0 ] && \
			log "no openssl or px5g — HTTPS unavailable; page stays on HTTP (opkg install openssl-util to enable)"
	fi
	uci commit firewall

	uci -q del_list "dhcp.@dnsmasq[0].address=/$domain/$alias"
	uci add_list "dhcp.@dnsmasq[0].address=/$domain/$alias"
	uci commit dhcp

	cfg_set ui_alias_ip "$alias"
	cfg_set ui_domain "$domain"

	/etc/init.d/network reload >/dev/null 2>&1
	/etc/init.d/dnsmasq reload >/dev/null 2>&1
	/etc/init.d/firewall reload >/dev/null 2>&1
	log "config page at http://$domain/ ($alias:80) and http://$(lan_ip):8099/"
}

# Undo everything cmd_ui_setup added (prerm). Leaves :8099 alone.
cmd_ui_teardown() {
	local domain alias zone
	domain=$(cfg_get ui_domain)
	alias=$(cfg_get ui_alias_ip)
	[ -n "$domain" ] && [ -n "$alias" ] && {
		uci -q del_list "dhcp.@dnsmasq[0].address=/$domain/$alias"
		uci commit dhcp
	}
	zone=$(ui_lan_zone) && uci -q del_list "firewall.@zone[$zone].network=bifrost_ui"
	uci -q delete firewall.bifrost_ui80
	uci -q delete firewall.bifrost_ui443
	uci -q delete firewall.bifrost_ui_tls
	uci commit firewall
	uci -q delete network.bifrost_ui && uci commit network
	rm -rf "$SSL_DIR"
	/etc/init.d/network reload >/dev/null 2>&1
	/etc/init.d/dnsmasq reload >/dev/null 2>&1
	/etc/init.d/firewall reload >/dev/null 2>&1
}

# Print what the port-80 path actually looks like right now. Each line is one of
# the things that has to be true for http://bifrost.lan/ to work, so a broken
# setup says which piece is missing instead of just failing in a browser.
cmd_ui_check() {
	local alias domain
	alias=$(cfg_get ui_alias_ip)
	domain=$(cfg_get ui_domain)
	echo "alias ip:  ${alias:-<none — page is on :8099 only>}"
	echo "domain:    ${domain:-<none>}"
	echo "on $(lan_dev):  $(ip -4 -o addr show "$(lan_dev)" 2>/dev/null | awk '{printf "%s ", $4}')"
	echo "dns:       $(nslookup "$domain" 127.0.0.1 2>/dev/null | awk '/^Address/ {a=$NF} END {print (a ? a : "does not resolve")}')"
	if uci -q get firewall.bifrost_ui80.src_dip >/dev/null 2>&1; then
		echo "http:      $(uci -q get firewall.bifrost_ui80.src_dip):80 -> $(uci -q get firewall.bifrost_ui80.dest_port)"
	else
		echo "http:      redirect MISSING — run 'bifrost ui-setup'"
	fi
	if ui_https_on; then
		echo "https:     $(uci -q get firewall.bifrost_ui443.src_dip):443 -> $(uci -q get firewall.bifrost_ui443.dest_port)  (self-signed — browsers warn)"
	elif [ "$(cfg_get ui_https)" = 0 ]; then
		echo "https:     disabled (ui_https=0)"
	else
		echo "https:     no cert — needs openssl or px5g (opkg install openssl-util)"
	fi
	echo "listening: $(netstat -ltn 2>/dev/null | awk '$4 ~ /:(8099|8443)$/ {printf "%s ", $4}')"
	echo "url:       $(ui_url)"
}

# Where the config page lives — the pretty name if the alias came up, else :8099.
ui_url() {
	local domain alias
	domain=$(cfg_get ui_domain)
	alias=$(cfg_get ui_alias_ip)
	if [ -n "$domain" ] && [ -n "$alias" ]; then
		if ui_https_on; then
			echo "https://$domain/"
		else
			echo "http://$domain/"
		fi
	else
		echo "http://$(lan_ip):8099/"
	fi
}

# ── entrypoint ──────────────────────────────────────────────────

case "${1:-}" in
	bootstrap) bootstrap ;;
	save-token) save_token "${2:-}" ;;
	poll) poll_once ;;
	provision | refresh) connect ;;
	# Pull the latest config from the master without touching the tunnel — the web UI
	# calls this to show dashboard changes (new sparks) live without reconnecting.
	fetch) fetch_config ;;
	# Manual triggers (the dashboard normally drives these via the provision poll).
	self-update) do_update ;;
	self-revert) do_revert ;;
	killswitch) apply_killswitch ;;
	up) cmd_up ;;
	down) cmd_down ;;
	status) cmd_status ;;
	json) cmd_json ;;
	ui-setup) cmd_ui_setup ;;
	ui-teardown) cmd_ui_teardown ;;
	ui-check) cmd_ui_check ;;
	ui-url) ui_url ;;
	run)
		# Health-gate a pending self-update: this (new) version must reach the master
		# within the window, or we roll back to the backup and re-exec it. A totally
		# broken new build that won't run at all can't self-heal here — procd just
		# respawns it — but the opkg install + checksums make that unlikely, and we
		# control releases.
		if [ -f "$PENDING" ]; then
			log "self-update pending — health-gating the new version"
			ok=0; i=0
			while [ "$i" -lt 12 ]; do   # ~60s to prove it can reach the master
				fetch_config >/dev/null 2>&1 && { ok=1; break; }
				i=$((i + 1)); sleep 5
			done
			if [ "$ok" = "1" ]; then
				rm -f "$PENDING"   # commit; keep the backup for a manual Revert
				log "self-update healthy — committed"
			else
				log "self-update failed its health check — rolling back to the backup"
				[ -f "$BAK" ] && cp "$BAK" /usr/bin/bifrost
				rm -f "$BAK" "$PENDING"
				exec /usr/bin/bifrost run   # re-exec the restored version
			fi
		fi

		# Reactive daemon: always running, re-reads uci each 5s tick and acts on
		# it, so the web UI only edits config and never restarts procd. Config is
		# re-fetched from the master (and return-to-primary attempted) every
		# refresh_interval, not every tick.
		interval=$(cfg_get refresh_interval); [ -n "$interval" ] || interval=300
		every=$((interval / 5)); [ "$every" -ge 1 ] || every=1
		tick=0
		while :; do
			apply_killswitch
			if [ -z "$(cfg_get provision_token)" ]; then
				[ -n "$(cfg_get device_code)" ] && poll_once   # complete pairing
			elif [ "$(cfg_get enabled)" = "1" ]; then
				if healthy; then
					if [ $((tick % every)) -eq 0 ]; then
						fetch_config && maybe_return_primary
						connect >/dev/null 2>&1 || true   # refresh; reapply only if changed
					fi
				else
					log "tunnel down — connecting (failover)"
					connect || log "connect failed; retrying"
				fi
			else
				# Disabled but a tunnel is up → tear it down.
				[ "$(handshake_age)" != none ] && teardown
			fi
			tick=$((tick + 1))
			sleep 5
		done
		;;
	*)
		echo "Usage: bifrost {bootstrap|save-token <t>|poll|up|down|status|json|refresh|run}" >&2
		exit 1
		;;
esac
