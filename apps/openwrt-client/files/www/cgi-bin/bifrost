#!/bin/sh
# Bifrost web-UI CGI. Served by the router's uhttpd (no LuCI required) at
# /cgi-bin/bifrost. Actions: status (GET), save|connect|disconnect|refresh (POST
# JSON body). Always replies with the `bifrost json` status document.
BIN=/usr/bin/bifrost

emit() { printf 'Content-Type: application/json\r\nCache-Control: no-cache\r\n\r\n%s\n' "$1"; }
status_json() { "$BIN" json 2>/dev/null || echo '{"state":"down"}'; }

action=""
provision_url=""
route_lan=""

if [ "${REQUEST_METHOD:-GET}" = "POST" ]; then
	len="${CONTENT_LENGTH:-0}"
	body=""
	case "$len" in
		*[!0-9]* | "") len=0 ;;
	esac
	[ "$len" -gt 0 ] && body="$(head -c "$len")"
	action="$(printf '%s' "$body" | jq -r '.action // empty' 2>/dev/null)"
	provision_url="$(printf '%s' "$body" | jq -r '.provisionUrl // empty' 2>/dev/null)"
	route_lan="$(printf '%s' "$body" | jq -r 'if has("routeLan") then (if .routeLan then "1" else "0" end) else "" end' 2>/dev/null)"
else
	action="$(printf '%s' "${QUERY_STRING:-}" | sed -n 's/.*action=\([^&]*\).*/\1/p')"
fi
[ -z "$action" ] && action=status

apply_settings() {
	[ -n "$provision_url" ] && uci set bifrost.settings.provision_url="$provision_url"
	[ -n "$route_lan" ] && uci set bifrost.settings.route_lan="$route_lan"
	uci commit bifrost 2>/dev/null
}

case "$action" in
	status)     emit "$(status_json)" ;;
	save)       apply_settings; emit "$(status_json)" ;;
	connect)    apply_settings; "$BIN" up >/dev/null 2>&1; emit "$(status_json)" ;;
	disconnect) "$BIN" down >/dev/null 2>&1; emit "$(status_json)" ;;
	refresh)    "$BIN" refresh >/dev/null 2>&1; emit "$(status_json)" ;;
	*)          emit '{"error":"unknown action"}' ;;
esac
