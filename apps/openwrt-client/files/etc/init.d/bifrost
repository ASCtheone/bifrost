#!/bin/sh /etc/rc.common
# procd init for the Bifrost VPN client.

USE_PROCD=1
START=95
STOP=10

start_service() {
	[ "$(uci -q get bifrost.settings.enabled)" = "1" ] || return 0
	[ -n "$(uci -q get bifrost.settings.provision_url)" ] || {
		logger -t bifrost "not starting: provision_url is empty"
		return 0
	}
	procd_open_instance
	procd_set_param command /usr/bin/bifrost run
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	local iface
	iface=$(uci -q get bifrost.settings.ifname); [ -n "$iface" ] || iface=bifrost
	ifdown "$iface" >/dev/null 2>&1 || true
}

service_triggers() {
	procd_add_reload_trigger "bifrost"
}
