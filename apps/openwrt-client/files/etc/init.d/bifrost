#!/bin/sh /etc/rc.common
# procd init for Bifrost. Runs two managed processes:
#   1. the config-page web server (its own uhttpd on :8099 — GL.iNet's uhttpd
#      won't run add-on instances, so we launch our own)
#   2. the VPN agent daemon (only once a provision URL is set + enabled)

USE_PROCD=1
START=95
STOP=10

start_service() {
	# Config page — one server, on :8099, on every address.
	#
	# It is deliberately NOT also bound to <alias>:80 to serve http://bifrost.lan/.
	# GL.iNet's own uhttpd binds the *wildcard* 0.0.0.0:80, which occupies port 80
	# on every address the router has — including our alias. Linux rejects an
	# overlapping bind while the existing socket is LISTENing (SO_REUSEADDR does
	# not help), so a second uhttpd on <alias>:80 fails with EADDRINUSE, respawns,
	# and GL.iNet's wildcard socket answers the alias instead — you'd land on their
	# dashboard. Port 80 is handled with a NAT redirect to :8099 instead, which the
	# kernel applies in PREROUTING, before the wildcard socket ever sees the packet.
	# See `bifrost ui-setup`.
	procd_open_instance webui
	procd_set_param command /usr/sbin/uhttpd -f -p 0.0.0.0:8099 -h /www/bifrost -x /cgi-bin -t 60 -T 30
	procd_set_param respawn
	procd_close_instance

	# HTTPS, when `bifrost ui-setup` managed to make a self-signed cert. Same
	# reasoning as :80 — GL.iNet's uhttpd wildcard-binds :443 as well when its UI
	# serves HTTPS, so we listen high and let a NAT redirect bring 443 here.
	if [ "$(uci -q get bifrost.settings.ui_https)" != 0 ] &&
		[ -s /etc/bifrost/ssl/cert.pem ] && [ -s /etc/bifrost/ssl/key.pem ]; then
		procd_open_instance webui_tls
		procd_set_param command /usr/sbin/uhttpd -f -s 0.0.0.0:8443 \
			-C /etc/bifrost/ssl/cert.pem -K /etc/bifrost/ssl/key.pem \
			-h /www/bifrost -x /cgi-bin -t 60 -T 30
		procd_set_param respawn
		procd_close_instance
	fi

	# VPN agent — always running; it reacts to the uci config (pairing, enabled,
	# location, kill switch) each cycle, so the web UI never has to restart procd.
	procd_open_instance agent
	procd_set_param command /usr/bin/bifrost run
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	local iface
	iface=$(uci -q get bifrost.settings.ifname); [ -n "$iface" ] || iface=bifrost
	ifdown "$iface" >/dev/null 2>&1 || true
}

service_triggers() {
	procd_add_reload_trigger "bifrost"
}
