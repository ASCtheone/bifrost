#!/bin/sh /etc/rc.common
# procd init for Bifrost. Runs two managed processes:
#   1. the config-page web server (its own uhttpd on :8099 — GL.iNet's uhttpd
#      won't run add-on instances, so we launch our own)
#   2. the VPN agent daemon (only once a provision URL is set + enabled)

USE_PROCD=1
START=95
STOP=10

start_service() {
	# Config page — always available so the router can be set up from a browser.
	procd_open_instance webui
	procd_set_param command /usr/sbin/uhttpd -f -p 0.0.0.0:8099 -h /www/bifrost -x /cgi-bin -t 60 -T 30
	procd_set_param respawn
	procd_close_instance

	# VPN agent — always running; it reacts to the uci config (pairing, enabled,
	# location, kill switch) each cycle, so the web UI never has to restart procd.
	procd_open_instance agent
	procd_set_param command /usr/bin/bifrost run
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	local iface
	iface=$(uci -q get bifrost.settings.ifname); [ -n "$iface" ] || iface=bifrost
	ifdown "$iface" >/dev/null 2>&1 || true
}

service_triggers() {
	procd_add_reload_trigger "bifrost"
}
