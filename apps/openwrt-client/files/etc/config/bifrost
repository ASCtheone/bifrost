config bifrost 'settings'
	# Control plane. Hard-bound to the Bifrost master by default — leave blank
	# unless you self-host, then set e.g. https://dash.example.com/bifrost
	option master_url ''

	# Set automatically by device-code registration. Don't edit by hand.
	option provision_token ''
	option device_code ''

	# Which spark to use: 'auto' (primary with failover + return-to-primary), or
	# a specific spark nodeId chosen on the config page.
	option location 'auto'

	# Kill switch: block LAN clients from the internet unless their traffic goes
	# through the tunnel — including while connecting or switching nodes.
	option killswitch '0'

	# Set to 1 to enable the tunnel (or use: bifrost up).
	option enabled '0'

	# Route the router's LAN clients through the VPN (firewall zone + masquerade).
	option route_lan '1'

	# Seconds between config refreshes / failover checks.
	option refresh_interval '300'

	# WireGuard interface name created on the router.
	option ifname 'bifrost'
