# Bifrost production stack — copy to .env and fill in. Do NOT commit .env.

# Stable secret used to sign dashboard JWTs. Keep it secret and unchanged
# (rotating it invalidates every active session). Generate one with:
#   openssl rand -hex 32
BIFROST_JWT_SECRET=

# ── Ingress: Cloudflare Tunnel (default) ────────────────────────────
# Token for the named Cloudflare Tunnel that fronts this stack. Create the
# tunnel in the Cloudflare Zero Trust dashboard (Networks → Tunnels), then map
# both public hostnames to  http://spark-server:8443 . Copy its token here.
TUNNEL_TOKEN=

# Public domains served by the tunnel (also used by the optional Caddy ingress).
DASHBOARD_DOMAIN=dash.asc.ninja
LANDING_DOMAIN=asc.ninja

# ── Optional: Caddy direct-exposure ingress (profile "caddy") ───────
# Only used when running  docker compose --profile caddy up  instead of the
# Cloudflare Tunnel. Email for the ACME (Let's Encrypt) account.
ACME_EMAIL=admin@asc.ninja

# Optional server log filter.
# RUST_LOG=spark_server=info,tower_http=info,sqlx=warn
